[mysqld]
# Кодировка — Bitrix работает в UTF-8 (utf8mb4 для полной поддержки Unicode)
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# Критично для Bitrix: отключаем строгий режим, который добавлен в MySQL 8 по умолчанию
# Без этого Bitrix бросает ошибки при работе со старыми запросами и схемами
sql_mode = ""

# MySQL 8 по умолчанию использует caching_sha2_password — Bitrix ожидает native_password
# (актуально для MySQL 8.0.x; в MySQL 8.4+ этот параметр убран)
default_authentication_plugin = mysql_native_password

# Производительность
innodb_buffer_pool_size = 256M
max_connections         = 100

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
